<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- WRITE_EXTERNAL_STORAGE is only needed below API 29; above that the
         game data goes into app-specific internal storage. -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- Meta Quest / VR headset feature declaration (not required for phone APKs) -->
    <uses-feature
        android:name="android.hardware.vr.headtracking"
        android:required="false" />

    <application
        android:name=".LauncherApplication"
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.MinelibLauncher">

        <!-- Splash / routing activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Microsoft device-code sign-in -->
        <activity
            android:name=".SignInActivity"
            android:exported="false" />

        <!-- Instance list, create, launch -->
        <activity
            android:name=".InstancesActivity"
            android:exported="false" />
    </application>
</manifest>
